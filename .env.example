OPENROUTER_API_KEY=sk-or-your-key-here

# Model ID — change to any model available on OpenRouter:
#   anthropic/claude-sonnet-4-5     (default)
#   anthropic/claude-opus-4
#   openai/gpt-4o
#   openai/gpt-4-turbo
#   meta-llama/llama-3.1-70b-instruct
#   google/gemini-pro-1.5 -tM,6DDzDqJ6e5U
AI_MODEL=anthropic/claude-sonnet-4-5

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SANDBOX_TIMEOUT=10
MAX_ARRAY_SIZE=64
LOG_LEVEL=INFO
ENV=development
DATABASE_URL=sqlite+aiosqlite:///./algo_visuals.db
